          "name": "Users",
          "item": [
            {
              "name": "Get Users",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Status code is 200\", function () {\r",
                      "    pm.response.to.have.status(200);\r",
                      "});\r",
                      "\r",
                      "pm.test(\"Response time is less than 1000ms\", function () {\r",
                      "    pm.response.to.have.property('responseTime').that.is.below(1000);\r",
                      "    });\r",
                      "    \r",
                      "pm.test(\"Response has data array\", function() {\r",
                      "    let jsonData = pm.response.json();\r",
                      "    pm.expect(jsonData.data).to.be.an(\"array\");\r",
                      "    });\r",
                      "pm.test(\"Data array has 6 objects\"), function() {\r",
                      "pm.collectionVariables.set(\"dataLength\", jsonData.data.length);\r",
                      "pm.expect(jsonData.data.length).to.equal(6);\r",
                      "}"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "auth": {
                  "type": "apikey",
