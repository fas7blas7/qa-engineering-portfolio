  "item": [
    {
      "name": "Create User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201 or 200\", function(){\r",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);\r",
              "})\r",
              "const json = pm.response.json();\r",
              "pm.environment.set(\"userId\", json.id);\r",
              "\r",
              "console.log(pm.response.json());"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"username\": \"testuser\",\r\n    \"email\": \"test@email.com\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users"
          ]
